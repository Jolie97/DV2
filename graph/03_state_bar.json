{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Fatal vs Non-Fatal Attacks by State",
  "width": "container",
  "height": 360,
  "config": {
    "background": "transparent",
    "font": "DM Sans",
    "title": {
      "color": "#e8f4f8",
      "fontSize": 14,
      "fontWeight": 600,
      "font": "Playfair Display"
    },
    "axis": {
      "labelColor": "rgba(232,244,248,0.5)",
      "tickColor": "transparent",
      "gridColor": "rgba(33,168,184,0.13)",
      "domainColor": "rgba(33,168,184,0.13)",
      "titleColor": "rgba(232,244,248,0.5)",
      "titleFontSize": 11
    },
    "legend": {
      "labelColor": "rgba(232,244,248,0.5)",
      "titleColor": "rgba(232,244,248,0.5)",
      "labelFontSize": 11
    },
    "view": {
      "stroke": "transparent"
    }
  },
  "data": {
    "url": "data/shark_attacks.csv"
  },
  "transform": [
    {
      "filter": "datum.injury == 'Fatal' || datum.injury == 'Non-Fatal'"
    },
    {
      "filter": "datum.state != ''"
    },
    {
      "aggregate": [
        {
          "op": "count",
          "as": "attacks"
        }
      ],
      "groupby": [
        "state",
        "injury"
      ]
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusTopLeft": 3,
    "cornerRadiusTopRight": 3
  },
  "encoding": {
    "x": {
      "field": "attacks",
      "type": "quantitative",
      "title": "Number of Attacks",
      "stack": null
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null,
      "sort": "-x"
    },
    "color": {
      "field": "injury",
      "type": "nominal",
      "title": "Outcome",
      "scale": {
        "domain": [
          "Non-Fatal",
          "Fatal"
        ],
        "range": [
          "#21a8b8",
          "#e05c4a"
        ]
      }
    },
    "opacity": {
      "value": 0.88
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "injury",
        "type": "nominal",
        "title": "Outcome"
      },
      {
        "field": "attacks",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}