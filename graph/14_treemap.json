{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Overall Attack Outcome Severity",
  "width": "container",
  "height": 360,
  "config": {
    "background": "transparent",
    "font": "DM Sans",
    "title": {
      "color": "#e8f4f8",
      "fontSize": 14,
      "fontWeight": 600,
      "font": "Playfair Display"
    },
    "axis": {
      "labelColor": "rgba(232,244,248,0.5)",
      "tickColor": "transparent",
      "gridColor": "rgba(33,168,184,0.13)",
      "domainColor": "rgba(33,168,184,0.13)",
      "titleColor": "rgba(232,244,248,0.5)",
      "titleFontSize": 11
    },
    "legend": {
      "labelColor": "rgba(232,244,248,0.5)",
      "titleColor": "rgba(232,244,248,0.5)",
      "labelFontSize": 11
    },
    "view": {
      "stroke": "transparent"
    }
  },
  "data": {
    "url": "data/shark_attacks.csv"
  },
  "transform": [
    {
      "filter": "datum.injury != ''"
    },
    {
      "aggregate": [
        {
          "op": "count",
          "as": "count"
        }
      ],
      "groupby": [
        "injury"
      ]
    },
    {
      "calculate": "'All Attacks'",
      "as": "category"
    }
  ],
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "count",
      "type": "quantitative",
      "title": "Number of Incidents",
      "stack": "normalize",
      "axis": {
        "format": ".0%",
        "title": "Proportion of All Attacks"
      }
    },
    "y": {
      "field": "category",
      "type": "nominal",
      "title": null
    },
    "color": {
      "field": "injury",
      "type": "nominal",
      "title": "Outcome",
      "scale": {
        "domain": [
          "Fatal",
          "Non-Fatal",
          "Uninjured"
        ],
        "range": [
          "#e05c4a",
          "#21a8b8",
          "#27ae60"
        ]
      }
    },
    "order": {
      "field": "count",
      "type": "quantitative",
      "sort": "descending"
    },
    "tooltip": [
      {
        "field": "injury",
        "type": "nominal",
        "title": "Outcome"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}